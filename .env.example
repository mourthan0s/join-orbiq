# ── Database (PostgreSQL — e.g. Supabase) ────────────────────────────────
# Runtime connection. With Supabase use the POOLED connection string
# (port 6543, pgbouncer) so serverless/route handlers don't exhaust
# connections: postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DATABASE_URL=

# Direct (non-pooled) connection, used ONLY by `prisma migrate` (port 5432).
# For local development set it to the same value as DATABASE_URL.
DIRECT_DATABASE_URL=

# ── App ──────────────────────────────────────────────────────────────────
# Public origin of the deployment (no trailing slash).
NEXT_PUBLIC_APP_URL=https://join.orbi-q.com
